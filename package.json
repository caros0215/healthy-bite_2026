{
  "name": "healthy-bite2",
  "version": "1.0.0",
  "private": true,
  "description": "Proyecto Healthy Bite: frontend, backend y XAMPP en ejecución conjunta.",
  "scripts": {
    "start": "concurrently \"npm run xampp\" \"npm run mysql\" \"npm --prefix frontend start\" \"npm --prefix backend start\"",
    "xampp": "powershell -ExecutionPolicy Bypass -File ./start-xampp.ps1",
    "mysql": "powershell -ExecutionPolicy Bypass -File ./start-mysql.ps1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.3"
  },
  "dependencies": {
    "@craco/craco": "^7.1.0",
    "axios": "^1.9.0",
    "bcrypt": "^6.0.0",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "fabric": "^6.6.5",
    "konva": "^9.3.20",
    "lucide-react": "^0.561.0",
    "mysql2": "^3.14.2",
    "node-fetch": "^3.3.2",
    "react-konva": "^19.0.3",
    "react-router-dom": "^7.6.0",
    "sharp": "^0.34.4",
    "ws": "^8.18.3",
    "zustand": "^5.0.4"
  }
}
